{
  "name": "futbol-3d",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Hareket kontrollü 3D futbol (penaltı) oyunu — kamerayla vücut takibi",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "cap:sync": "npm run build && cap sync",
    "android:add": "cap add android",
    "android:open": "npm run build && cap sync && cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@dimforge/rapier3d-compat": "^0.19.3",
    "@mediapipe/tasks-vision": "^0.10.35",
    "three": "^0.185.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@eslint/js": "^10.0.1",
    "@types/three": "^0.185.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
